# --- Database -----------------------------------------------------------
# When unset, RosterIQ runs on an embedded PGlite (Postgres) database stored
# in .data/pglite — zero-config local development.
# For production, point at a managed Postgres (e.g. Supabase):
# DATABASE_URL=postgres://user:password@host:5432/rosteriq

# --- Auth ---------------------------------------------------------------
# Auth provider: "local" (built-in credentials, default) or "supabase".
# AUTH_PROVIDER=local
# Secret used to sign session tokens. REQUIRED in production.
# Generate with: openssl rand -hex 32
# SESSION_SECRET=

# --- Supabase (only when AUTH_PROVIDER=supabase) ------------------------
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# --- AI assistant (future; provider abstraction, OFF by default) --------
# LLM_PROVIDER=none
# LLM_API_KEY=
